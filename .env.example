OLLAMA_HOST=http://localhost:11434

# Multi-model resident profile — all agents stay loaded in VRAM
OLLAMA_MAX_LOADED_MODELS=3
OLLAMA_NUM_PARALLEL=4

HORNET_ORCHESTRATOR_MODEL=qwen2.5-coder:32b
HORNET_SQL_MODEL=sqlcoder:15b
HORNET_STATS_MODEL=mathstral:7b
HORNET_RESIDENT_MODELS=true

# Paths (defaults work out of the box)
# On Linux server installs set this explicitly, e.g. /opt/hornet/app/HORNET
# HORNET_ROOT=/opt/hornet/app/HORNET
HORNET_DATA_DIR=data
HORNET_LOG_LEVEL=INFO
