OLLAMA_HOST=http://localhost:11434

# Hot models (always loaded during sessions)
HORNET_ORCHESTRATOR_MODEL=qwen2.5-coder:32b
HORNET_SQL_MODEL=sqlcoder:7b

# On-demand model (loaded when stats narrative is needed)
HORNET_STATS_MODEL=mathstral:7b

# Paths (defaults work out of the box)
HORNET_DATA_DIR=data
HORNET_LOG_LEVEL=INFO
